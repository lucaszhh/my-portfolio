---
import ExperienceItem from "../cards/ExperienceItem.astro";
import { experiences } from "../../data/experience";

const experienceCards = experiences.map((experience) => ({
    date: experience.period,
    title: `${experience.role} — ${experience.company}`,
    description: experience.bullets.join(" "),
    linkDescription: experience.link?.label ?? "Ver más",
    link: experience.link?.href,
    linkExternal: experience.link?.external,
}));
const EXPERIENCE_LIMIT = 3;
---

<section class="py-8">
    <h2 class="text-4xl font-bold pb-6">Experiencia profesional</h2>
    <span id="experience-more" class="experience-target" aria-hidden="true"></span>
    <ol class="experience-list relative border-s border-gray-200 ml-3">
        {
            experienceCards.map((experience, index) => (
                <li
                    class={`transition ease-in mb-10 ms-4 max-w-3xl ${
                        index >= EXPERIENCE_LIMIT ? "experience-more" : ""
                    }`}
                >
                    <ExperienceItem {...experience} />
                </li>
            ))
        }
    </ol>
    <div class="toggle-actions flex justify-center">
        <a
            href="/#experience-more"
            class="toggle-button toggle-more w-auto flex items-center gap-2 border border-black bg-black text-white rounded-3xl hover:text-black dark:text-white hover:bg-white dark:hover:border-[#63e] dark:hover:bg-black dark:bg-[#63e] h-10 px-6 cursor-pointer active:scale-[1.1] transition-all duration-300 hover:shadow-lg"
        >
            <span class="text-sm font-bold">VER MÁS</span>
        </a>
        <a
            href="/#experience"
            class="toggle-button toggle-less w-auto flex items-center gap-2 border border-black bg-black text-white rounded-3xl hover:text-black dark:text-white hover:bg-white dark:hover:border-[#63e] dark:hover:bg-black dark:bg-[#63e] h-10 px-6 cursor-pointer active:scale-[1.1] transition-all duration-300 hover:shadow-lg"
        >
            <span class="text-sm font-bold">VER MENOS</span>
        </a>
    </div>
</section>

<style>
    .experience-target {
        display: block;
        height: 0;
        width: 0;
    }

    .experience-more {
        display: none;
    }

    .toggle-less {
        display: none;
    }

    #experience-more:target ~ .experience-list .experience-more {
        display: block;
    }

    #experience-more:target ~ .toggle-actions .toggle-more {
        display: none;
    }

    #experience-more:target ~ .toggle-actions .toggle-less {
        display: inline-flex;
    }
</style>
