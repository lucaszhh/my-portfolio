---
import { designSystem } from "../../data/designSystem";
---

<section class="py-8">
    <h2 class="text-4xl font-bold pb-2">{designSystem.title}</h2>
    <p class="text-sm text-gray-700 dark:text-gray-200 pb-6">
        {designSystem.subtitle}
    </p>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {designSystem.capabilities.map((capability) => (
            <article
                class="drop-shadow-lg bg-white dark:bg-black border rounded-xl p-4 flex flex-col gap-2"
            >
                <h3 class="text-lg font-semibold">{capability.title}</h3>
                <p class="text-sm text-gray-700 dark:text-gray-200">
                    {capability.description}
                </p>
            </article>
        ))}
    </div>
</section>
