---
import { homeProjects } from "../../data/projects";
import type { LinkItem } from "../../data/types";
import ProjectsCarousel from "../projects/ProjectsCarousel";

const getLink = (links: LinkItem[] | undefined, label: string) =>
    links?.find((link) => link.label === label)?.href;

const carouselItems = homeProjects.map((project) => ({
    id: project.id,
    title: project.name,
    subtitle: project.subtitle ?? "",
    image: project.image ?? "",
    stack: project.stack ?? [],
    github: getLink(project.links, "GitHub") ?? "",
    link: getLink(project.links, "Live") ?? "",
    cdf: project.cdf ?? false,
}));
---

<section class="py-4">
    <h2 class="text-4xl font-bold">Proyectos</h2>
</section>
<ProjectsCarousel client:visible items={carouselItems} />
